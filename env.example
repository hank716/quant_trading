FINMIND_TOKEN=
DATA_PROVIDER=official_hybrid
OFFICIAL_TLS_INSECURE_FALLBACK=true
OFFICIAL_TLS_INSECURE_FALLBACK_HOSTS=mopsfin.twse.com.tw,openapi.twse.com.tw,www.twse.com.tw,www.tpex.org.tw


# 說明文字用的 provider: rule_based / groq / openai_compatible / none
LLM_PROVIDER=groq

# 候選標的挑選用的 provider: rule_based / groq / openai_compatible / none
SELECTION_PROVIDER=groq

# v8 抗 rate limit 相關設定
# true: 若 selector 已用同一個外部 LLM，說明層自動改為 rule_based，只打 1 次 API
LLM_SAFE_MODE=true
# 同一進程兩次 LLM 呼叫之間至少等待秒數
LLM_MIN_INTERVAL_SECONDS=3
# 429 或暫時性錯誤最多重試次數
LLM_MAX_RETRIES=4
# 重試退避的基礎秒數
LLM_RETRY_BACKOFF_SECONDS=2
# 是否啟用 LLM 回應快取
LLM_CACHE_ENABLED=true
# LLM 回應快取路徑
LLM_CACHE_DIR=.cache/llm

# Groq settings
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-20b

# Optional generic OpenAI-compatible fallback
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Discord webhooks for different profiles
DISCORD_WEBHOOK_URL_DEFAULT=
DISCORD_WEBHOOK_URL_USER_A=
DISCORD_WEBHOOK_URL_USER_B=

# === Core ===
USE_MOCK_DATA=1
CACHE_DIR=./workspace/hotdata
OUTPUT_DIR=./workspace/outputs
LOG_DIR=./workspace/logs

# === Anthropic ===
ANTHROPIC_API_KEY=

# === pCloud API（Phase 2+）===
PCLOUD_TOKEN=
PCLOUD_REGION=eu
PCLOUD_ROOT_FOLDER=/fin-quant

# === Supabase（Phase 3+）===
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Supabase direct DB connection（Grafana PostgreSQL datasource 用）
SUPABASE_DB_HOST=db.<project-id>.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=

# Phase 8+: MLflow
MLFLOW_TRACKING_URI=file:workspace/mlruns
