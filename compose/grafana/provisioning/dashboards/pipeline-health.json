{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "postgres", "name": "PostgreSQL", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "fin pipeline health — run status, candidate counts, coverage",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL_(SUPABASE)}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red",   "value": 0 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto",
        "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto" },
      "title": "最近 Run 狀態",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL_(SUPABASE)}" },
          "rawSql": "SELECT CASE status WHEN 'success' THEN 1 ELSE 0 END AS value FROM pipeline_runs ORDER BY started_at DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL_(SUPABASE)}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto" },
      "title": "最近候選標的數",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL_(SUPABASE)}" },
          "rawSql": "SELECT COUNT(*) AS value FROM daily_candidates WHERE run_id = (SELECT run_id FROM pipeline_runs ORDER BY started_at DESC LIMIT 1) AND list_type = 'eligible'",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL_(SUPABASE)}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "status" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "mappings", "value": [
                { "type": "value", "options": { "success": { "color": "green", "index": 0 } } },
                { "type": "value", "options": { "failed":  { "color": "red",   "index": 1 } } },
                { "type": "value", "options": { "running": { "color": "blue",  "index": 2 } } }
              ]}
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "id": 3,
      "options": { "footer": { "show": false }, "showHeader": true },
      "title": "近期 Pipeline Runs",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL_(SUPABASE)}" },
          "rawSql": "SELECT run_id, trade_date, mode, status, git_commit, started_at, ended_at, notes FROM pipeline_runs ORDER BY started_at DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL_(SUPABASE)}" },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 4,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" } },
      "title": "每日候選標的數趨勢",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL_(SUPABASE)}" },
          "rawSql": "SELECT trade_date AS time, COUNT(*) AS eligible FROM daily_candidates WHERE list_type = 'eligible' GROUP BY trade_date ORDER BY trade_date",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL_(SUPABASE)}" },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 }, "min": 0, "max": 100,
        "unit": "percent" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 5,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" } },
      "title": "財報覆蓋率趨勢",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL_(SUPABASE)}" },
          "rawSql": "SELECT trade_date AS time, revenue_coverage * 100 AS \"月營收覆蓋率\", financial_coverage * 100 AS \"財報覆蓋率\" FROM coverage_snapshots ORDER BY trade_date",
          "format": "time_series",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "tags": ["fin", "pipeline"],
  "templating": { "list": [] },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Taipei",
  "title": "Pipeline Health",
  "uid": "fin-pipeline-health",
  "version": 1
}
